{
  "manifest_version": 3,
  "name": "Claude Lightpuck",
  "version": "1.0",
  "description": "Sends Claude usage data to Lightpuck LED server",
  "permissions": ["alarms"],
  "host_permissions": [
    "https://claude.ai/*",
    "http://100.81.93.115:8080/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
